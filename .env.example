# ============================================
# TELEGRAM
# ============================================
# Токен бота от @BotFather (https://t.me/BotFather)
# Формат: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=your_bot_token_here

# ============================================
# BITRIX24
# ============================================
# URL вебхука из Bitrix24 (не обязательно для локального теста)
# Формат: https://your-portal.bitrix24.ru/rest/1/YOUR_CODE/
BITRIX_WEBHOOK_URL=

# Секрет вебхука (если есть, не обязательно)
BITRIX_WEBHOOK_SECRET=

# ============================================
# DATABASE
# ============================================
# PostgreSQL (для Docker)
DATABASE_URL=postgresql://bot_user:password@localhost:5432/onboarding_bot

# ============================================
# REDIS
# ============================================
# Redis (не обязательно для локального теста)
REDIS_URL=redis://localhost:6379/0

# ============================================
# APPLICATION
# ============================================
# Режим: development или production
APP_ENV=development

# Часовой пояс
TIMEZONE=Europe/Moscow

# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=DEBUG

# ============================================
# BOT SETTINGS
# ============================================
# Время отправки напоминаний (час, 0-23)
BOT_SEND_TIME_HOUR=9

# Начало рабочего времени (час)
BOT_WORK_HOURS_START=9

# Конец рабочего времени (час)
BOT_WORK_HOURS_END=18

# Максимум напоминаний по одной сделке
BOT_MAX_REMINDERS=30

# ============================================
# SECURITY
# ============================================
# Секрет для проверки webhook (для локального теста можно любой)
WEBHOOK_SECRET_KEY=local_dev_secret_key_123
